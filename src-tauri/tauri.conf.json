{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Prism",
  "version": "0.1.0",
  "identifier": "com.prism.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prism",
        "width": 1000,
        "height": 600,
        "minWidth": 600,
        "minHeight": 600,
        "resizable": true
      },
      {
        "label": "floating",
        "title": "Prism",
        "width": 260,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "dragDropEnabled": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "url": "/?window=floating"
      },
      {
        "label": "import",
        "title": "Import",
        "width": 400,
        "height": 560,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "dragDropEnabled": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "url": "/?window=import"
      },
      {
        "label": "selector",
        "title": "Prism",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "fullscreen": true,
        "url": "/?window=selector"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
